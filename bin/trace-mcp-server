#!/usr/bin/env python3
"""TRACE MCP Server launcher — .pth-safe entry point.

Workaround for Python 3.13 + macOS UF_HIDDEN flag interaction:

    macOS propagates the UF_HIDDEN file flag to all files inside directories
    whose names start with "." (like .venv/). Python 3.13's site.addpackage()
    skips .pth files that have UF_HIDDEN set (via os.stat().st_flags & UF_HIDDEN).
    This means editable installs using .pth files silently break — the source
    path never gets added to sys.path, causing ModuleNotFoundError.

This script explicitly inserts src/ into sys.path before importing trace_mcp,
so it works regardless of whether .pth files are processed. It is the
recommended entry point for .mcp.json configurations.

Usage in .mcp.json:
    {
      "mcpServers": {
        "trace": {
          "command": "/path/to/TRACE/.venv/bin/python",
          "args": ["/path/to/TRACE/bin/trace-mcp-server"]
        }
      }
    }

Or with uv:
    {
      "mcpServers": {
        "trace": {
          "command": "uv",
          "args": ["run", "--directory", "/path/to/TRACE",
                   "python", "/path/to/TRACE/bin/trace-mcp-server"]
        }
      }
    }
"""
from __future__ import annotations

import sys
from pathlib import Path

# Compute the src/ directory relative to this script:
#   bin/trace-mcp-server -> parent is bin/ -> parent.parent is TRACE root -> / src
_src_dir = str(Path(__file__).resolve().parent.parent / "src")

if _src_dir not in sys.path:
    sys.path.insert(0, _src_dir)

from trace_mcp.server import main  # noqa: E402

if __name__ == "__main__":
    main()
else:
    # When executed via `python bin/trace-mcp-server`, __name__ is "__main__".
    # This branch handles the edge case of being imported as a module.
    main()
